{
    "version":  "1.0",
    "linkerSettings":  {
                           "windows":  {
                                           "x64":  {
                                                       "additionalDependencies":  "jpeg.lib;libpng16.lib;libwebp.lib;libwebpdecoder.lib;libwebpdemux.lib;libwebpmux.lib;lzma.lib;tiff.lib;turbojpeg.lib;utf8_range.lib;utf8_validity.lib;MachineIndependent.lib;libsharpyuv.lib;opencv_world4.lib;zlib.lib;ncnn.lib;glslang.lib;%(AdditionalDependencies)",
                                                       "additionalLibraryDirectories":  "D:\\vcpkg\\installed\\x64-windows-static\\lib;%(AdditionalLibraryDirectories)"
                                                   }
                                       }
                       },
    "externDeclarations":  {
                               "common":  [
                                              "extern \"C\" const char* yolo_version(void);",
                                              "extern \"C\" int yolo_sun(int a, int b);",
                                              "extern \"C\" int yolo_get_ncnn_gpu_count(void);",
                                              "extern \"C\" char* yolo_get_ncnn_runtime_info_json(void);",
                                              "extern \"C\" bool yolo_generate_class_labels(const char* directory_path, const char* output_file);",
                                              "extern \"C\" void yolo_release_ncnn_global_resources(void);",
                                              "struct YOLO11;",
                                              "extern \"C\" YOLO11* yolo_load_model_from_file(const char* param_path, const char* model_path, int yolo_version, int picsize, bool ncnngpu, bool use_fp16);",
                                              "extern \"C\" YOLO11* yolo_load_model_from_memory(const unsigned char* param_data, size_t param_len, const unsigned char* model_data, size_t model_len, int yolo_version, int picsize, bool ncnngpu, bool use_fp16);",
                                              "extern \"C\" void yolo_release_model(YOLO11* yolo);",
                                              "extern \"C\" void yolo_release_model_ref(YOLO11** yolo);",
                                              "extern \"C\" void* yolo_detect_objects(YOLO11* yolo, const unsigned char* image_data, size_t image_len, int task_type);",
                                              "extern \"C\" void* yolo_detect_objects_raw(YOLO11* yolo, const unsigned char* bgr_data, int width, int height, int task_type);",
                                              "extern \"C\" int yolo_get_objects_count(void* objects);",
                                              "extern \"C\" void yolo_get_object_info(void* objects, int index, float* x, float* y, float* w, float* h, int* label, float* prob);",
                                              "extern \"C\" void yolo_free_objects_vector(void* objects);"
                                          ]
                           },
    "controlBindings":  [

                        ],
    "eventBindings":  [

                      ],
    "commandBindings":  [
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.version",
                                "emit":  "yc_utf8_to_wide(yolo_version())"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.sun",
                                "emit":  "yolo_sun({0|0}, {1|0})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.getNcnnGpuCount",
                                "emit":  "yolo_get_ncnn_gpu_count()"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.getNcnnRuntimeInfoJson",
                                "emit":  "yc_utf8_to_wide(yolo_get_ncnn_runtime_info_json())"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.releaseNcnnGlobalResources",
                                "emit":  "yolo_release_ncnn_global_resources()"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.generateClassLabels",
                                "emit":  "yolo_generate_class_labels({0|\"\"}, {1|\"\"})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.loadModelFromFile",
                                "emit":  "(long long)(intptr_t)yolo_load_model_from_file({0|\"\"}, {1|\"\"}, {2|11}, {3|640}, {4|1}, {5|1})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.loadModelFromMemory",
                                "emit":  "(long long)(intptr_t)yolo_load_model_from_memory(({0|}.empty() ? NULL : (const unsigned char*)({0|}.data())), (size_t)({1|0}), ({2|}.empty() ? NULL : (const unsigned char*)({2|}.data())), (size_t)({3|0}), {4|11}, {5|640}, {6|1}, {7|1})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.releaseModel",
                                "emit":  "yolo_release_model((YOLO11*)(intptr_t)({0|0}))"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.releaseModelRef",
                                "emit":  "yolo_release_model_ref((YOLO11**)(intptr_t)({0|0}))"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.detectObjects",
                                "emit":  "(long long)(intptr_t)yolo_detect_objects((YOLO11*)(intptr_t)({0|0}), ({1|}.empty() ? NULL : (const unsigned char*)({1|}.data())), (size_t)({2|0}), {3|0})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.detectObjectsRaw",
                                "emit":  "(long long)(intptr_t)yolo_detect_objects_raw((YOLO11*)(intptr_t)({0|0}), ({1|}.empty() ? NULL : (const unsigned char*)({1|}.data())), {2|0}, {3|0}, {4|0})"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.getObjectsCount",
                                "emit":  "yolo_get_objects_count((void*)(intptr_t)({0|0}))"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.getObjectInfo",
                                "emit":  "yolo_get_object_info((void*)(intptr_t)({0|0}), {1|0}, (float*)({\u00262|0}), (float*)({\u00263|0}), (float*)({\u00264|0}), (float*)({\u00265|0}), (int*)({\u00266|0}), (float*)({\u00267|0}))"
                            },
                            {
                                "library":  "yolo",
                                "commandEnglishName":  "yolo.freeObjectsVector",
                                "emit":  "yolo_free_objects_vector((void*)(intptr_t)({0|0}))"
                            }
                        ]
}
